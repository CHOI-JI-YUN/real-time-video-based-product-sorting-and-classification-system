<mah:MetroWindow x:Class="VisiPickHMI.DateSelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        Title="날짜별 로그 불러오기"
        TitleCharacterCasing="Normal"
        WindowTitleBrush="#0B1120"
        TitleBarHeight="32"
        TitleForeground="#94A3B8"
        GlowBrush="#3B82F6"
        Width="320" Height="420"
        MinWidth="280" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="#0B1120"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="불러올 날짜를 선택하세요"
                   FontSize="12" Foreground="#94A3B8" Margin="0,0,0,10"/>

        <Border Grid.Row="1" Background="#151F35" BorderBrush="#1E2D4A"
                BorderThickness="1" CornerRadius="6">
            <ListBox x:Name="DateListBox"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="#E2E8F0"
                     FontSize="13"
                     FontFamily="Consolas"
                     ItemsSource="{Binding}"
                     MouseDoubleClick="DateListBox_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1A2744"/>
                                <Setter Property="Foreground" Value="#22D3EE"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#111B2E"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="취소" Width="80" Height="32"
                    Foreground="#94A3B8" Background="#1E2D4A"
                    BorderThickness="0" Cursor="Hand"
                    FontSize="12" Margin="0,0,8,0"
                    Click="Cancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="불러오기" Width="90" Height="32"
                    Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontSize="12" FontWeight="SemiBold"
                    Click="Load_Click">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#3B82F6" Offset="0"/>
                        <GradientStop Color="#2563EB" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
