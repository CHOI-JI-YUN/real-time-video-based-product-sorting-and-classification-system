<mah:MetroWindow x:Class="VisiPickHMI.EmergencyAlertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        Title="⚠ 비상정지" TitleCharacterCasing="Normal"
        WindowTitleBrush="#7F0000" GlowBrush="#FF3B30"
        TitleBarHeight="32" TitleForeground="White"
        Width="420" Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#0B1120">

    <Grid>
        <!-- 붉은 테두리 강조 -->
        <Border BorderBrush="#FF3B30" BorderThickness="2" CornerRadius="4" Margin="12">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">

                <!-- 경고 아이콘 -->
                <TextBlock Text="🚨" FontSize="52" HorizontalAlignment="Center"
                           Margin="0,0,0,12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1" To="0.3" Duration="0:0:0.5"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Text="비 상 정 지" FontSize="26" FontWeight="Bold"
                           Foreground="#FF3B30" HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                <TextBlock Text="E-STOP 신호가 발생했습니다." FontSize="13"
                           Foreground="#94A3B8" HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                <TextBlock Text="모든 장비가 정지되었습니다." FontSize="13"
                           Foreground="#94A3B8" HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <Button Content="✔ 확인 (알람 해제)" Width="180" Height="36"
                        FontSize="13" FontWeight="SemiBold" Foreground="White"
                        Background="#C62828" BorderThickness="0"
                        Cursor="Hand" Click="Confirm_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="12,6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#E53935"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</mah:MetroWindow>
