<mah:MetroWindow x:Class="VisiPickHMI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        Title="VisiPick"
        TitleCharacterCasing="Normal"
        WindowState="Maximized"
        WindowStyle="None"
        ShowTitleBar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#031127"
        AllowsTransparency="False">

    <Grid Background="#031127">
        <Viewbox Stretch="Uniform"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Margin="40">
            <!-- 레퍼런스 이미지 비율 1448:1086 ≈ 4:3 -->
            <Grid Width="1448" Height="1086">

                <!-- 전체 배경 (어두운 네이비) -->
                <Border Background="#031127" CornerRadius="16"/>

                <!-- 배경 이미지: 좌측 전체를 채움 -->
                <Image Source="pack://application:,,,/Assets/login_bg.png"
                       Stretch="UniformToFill"
                       Opacity="0.94"
                       HorizontalAlignment="Left"
                       Width="880"
                       RenderOptions.BitmapScalingMode="HighQuality" Margin="106,122,0,110">
                    <Image.OpacityMask>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFFFFFFF" Offset="0"/>
                            <GradientStop Color="#FFFFFFFF" Offset="0.6"/>
                            <GradientStop Color="#00FFFFFF" Offset="0.95"/>
                        </LinearGradientBrush>
                    </Image.OpacityMask>
                </Image>

                <!-- 로그인 카드: 우측 배치 -->
                <Border HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="770,0,0,0"
                        Width="480"
                        Height="620"
                        Background="#CC071325"
                        BorderBrush="#10FFFFFF"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="48,70">

                    <StackPanel VerticalAlignment="Center">

                        <TextBlock Text="로그인"
                                   FontSize="38"
                                   FontWeight="Bold"
                                   Foreground="#E2E8F0"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="스마트팩토리 HMI 시스템"
                                   FontSize="19"
                                   Foreground="#5A7090"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,40"/>

                        <Border x:Name="ErrorBorder"
                                Visibility="Collapsed"
                                Background="#CC1C0A0A"
                                BorderBrush="#7F1D1D"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16,10"
                                Margin="0,0,0,18">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="⚠" FontSize="15" Foreground="#F87171"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock x:Name="TxtError" FontSize="14" Foreground="#FCA5A5"
                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- 사용자 ID -->
                        <Border Background="#081828" BorderBrush="#15FFFFFF" BorderThickness="1"
                                CornerRadius="10" Height="56" Margin="0,0,0,20">
                            <Grid Margin="20,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0"
                                      Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                                      Fill="#4A6585" Stretch="Uniform" Width="22" Height="22"
                                      VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <TextBox Grid.Column="1" x:Name="TxtUsername"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="#E2E8F0" FontSize="18"
                                         CaretBrush="#FFFFFF" SelectionBrush="#3B82F6"
                                         VerticalContentAlignment="Center"
                                         Padding="2,0,0,0"
                                         KeyDown="Input_KeyDown"/>
                                <TextBlock Grid.Column="1" Text="사용자 ID"
                                           FontSize="18" Foreground="#3A5575"
                                           VerticalAlignment="Center" Margin="6,0,0,0" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=TxtUsername, Path=Text}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- 비밀번호 -->
                        <Border Background="#081828" BorderBrush="#15FFFFFF" BorderThickness="1"
                                CornerRadius="10" Height="56" Margin="0,0,0,20">
                            <Grid Margin="20,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0"
                                      Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.1,13 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V10C4,8.89 4.9,8 6,8H7V6A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,3A3,3 0 0,0 9,6V8H15V6A3,3 0 0,0 12,3Z"
                                      Fill="#4A6585" Stretch="Uniform" Width="22" Height="22"
                                      VerticalAlignment="Center" Margin="0,0,14,0" Cursor=""/>

                                <TextBlock Grid.Column="1"
                                           x:Name="TxtPasswordPlaceholder"
                                           Text="비밀번호"
                                           FontSize="18"
                                           Foreground="#3A5575"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0"
                                           IsHitTestVisible="False" Cursor=""/>

                                <PasswordBox Grid.Column="1" x:Name="TxtPassword"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="#E2E8F0" FontSize="18"
                                             CaretBrush="#FFFFFF"
                                             VerticalContentAlignment="Center"
                                             Padding="2,0,0,0"
                                             PasswordChanged="TxtPassword_PasswordChanged"
                                             KeyDown="Input_KeyDown"/>
                                <TextBox Grid.Column="1"
                                         x:Name="TxtPasswordVisible"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#E2E8F0"
                                         FontSize="18"
                                         CaretBrush="#FFFFFF"
                                         VerticalContentAlignment="Center"
                                         Padding="2,0,0,0"
                                         Visibility="Collapsed"
                                         KeyDown="Input_KeyDown"/>

                                <TextBlock Grid.Column="2" x:Name="BtnTogglePw"
                                           Text="👁" FontSize="20" Foreground="#4A6585"
                                           VerticalAlignment="Center" Cursor="Hand"
                                           MouseLeftButtonDown="TogglePassword_Click"/>
                            </Grid>
                        </Border>

                        <!-- 아이디 저장 + 비밀번호 찾기 -->
                        <Grid Margin="4,4,4,30">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <CheckBox x:Name="ChkRemember" VerticalAlignment="Center" Cursor="Hand"
                                          RenderTransformOrigin="0.5,0.5">
                                    <CheckBox.RenderTransform>
                                        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                    </CheckBox.RenderTransform>
                                </CheckBox>
                                <TextBlock Text="아이디 저장" FontSize="16" Foreground="#5A7090"
                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="16" Foreground="#3B82F6" Cursor="Hand"
                                       Text="비밀번호 찾기"
                                       MouseLeftButtonDown="FindPassword_Click"/>
                        </Grid>

                        <!-- 로그인 버튼 -->
                        <Button x:Name="BtnLogin" Height="60" Cursor="Hand" Click="Login_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="btnBg" CornerRadius="10" Height="60">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#1D4ED8" Offset="0"/>
                                                <GradientStop Color="#3B82F6" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="로그인" FontSize="20" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="btnBg" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="btnBg" Property="Opacity" Value="0.78"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock Text="© 2026 VISIPICK Smart Factory System"
                                   FontSize="14" Foreground="#3A5575"
                                   HorizontalAlignment="Center" Margin="0,24,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Viewbox>

        <!-- 우측 상단: 전체 현장 CCTV 보기 버튼 -->
        <Button x:Name="BtnSiteCamera"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,28,36,0" Height="44" Cursor="Hand"
                Click="SiteCamera_Click"
                ToolTip="전체 현장 CCTV 보기">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="camBg" CornerRadius="22"
                            Background="#CC0B1B33"
                            BorderBrush="#2A3F63" BorderThickness="1"
                            Padding="16,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="M17,10.5V7A1,1 0 0,0 16,6H4A1,1 0 0,0 3,7V17A1,1 0 0,0 4,18H16A1,1 0 0,0 17,17V13.5L21,17.5V6.5L17,10.5Z"
                                  Fill="#3B82F6" Stretch="Uniform" Width="22" Height="22"
                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="현장 CCTV" FontSize="15" FontWeight="SemiBold"
                                       Foreground="#CBD5E1" VerticalAlignment="Center"/>
                            <Ellipse x:Name="DotCctv" Width="7" Height="7" Fill="#FF3B30" Margin="9,0,0,0"
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="camBg" Property="Background" Value="#E6112644"/>
                            <Setter TargetName="camBg" Property="BorderBrush" Value="#3B82F6"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="camBg" Property="Opacity" Value="0.8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</mah:MetroWindow>
