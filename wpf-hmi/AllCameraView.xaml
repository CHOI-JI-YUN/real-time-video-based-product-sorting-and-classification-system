<mah:MetroWindow x:Class="VisiPickHMI.AllCameraView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        Title="전체 카메라 보기  |  VisiPick"
        TitleCharacterCasing="Normal"
        GlowBrush="#3B82F6"
        NonActiveGlowBrush="#1E2D4A"
        WindowTitleBrush="#0B1120"
        NonActiveWindowTitleBrush="#0B1120"
        TitleBarHeight="32"
        TitleForeground="#94A3B8"
        Width="1280" Height="600"
        MinWidth="860" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#0B1120">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ Camera 1 (좌) ══ -->
        <Border Grid.Column="0"
                Background="#151F35"
                BorderBrush="#1E2D4A"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <Border Width="4" Height="14" CornerRadius="2" Margin="0,0,8,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#3B82F6" Offset="0"/>
                                <GradientStop Color="#22D3EE" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="📷 Camera 1" FontSize="13" FontWeight="SemiBold"
                               Foreground="#94A3B8" VerticalAlignment="Center"/>
                    <Ellipse x:Name="DotCam1" Width="7" Height="7" Fill="#FF3B30"
                             Margin="10,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LiveLabelCam1" Text="OFFLINE" FontSize="9" Foreground="#FF3B30"
                               Margin="4,0,0,0" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Row="1" Background="#0A0F1C" CornerRadius="6"
                        BorderBrush="#1E2D4A" BorderThickness="1">
                    <Grid>
                        <Image x:Name="ImgCamera1"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        <StackPanel x:Name="PlaceholderCam1"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📷" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Camera 1 대기 중..." FontSize="14"
                                       Foreground="#94A3B8" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ══ Splitter ══ -->
        <GridSplitter Grid.Column="1" Width="8"
                      HorizontalAlignment="Stretch"
                      Background="Transparent"
                      Cursor="SizeWE"/>

        <!-- ══ Camera 2 (우) ══ -->
        <Border Grid.Column="2"
                Background="#151F35"
                BorderBrush="#1E2D4A"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <Border Width="4" Height="14" CornerRadius="2" Margin="0,0,8,0"
                            Background="#22D3EE"/>
                    <TextBlock Text="📷 Camera 2" FontSize="13" FontWeight="SemiBold"
                               Foreground="#94A3B8" VerticalAlignment="Center"/>
                    <Ellipse x:Name="DotCam2" Width="7" Height="7" Fill="#FF3B30"
                             Margin="10,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LiveLabelCam2" Text="OFFLINE" FontSize="9" Foreground="#FF3B30"
                               Margin="4,0,0,0" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Row="1" Background="#0A0F1C" CornerRadius="6"
                        BorderBrush="#1E2D4A" BorderThickness="1">
                    <Grid>
                        <Image x:Name="ImgCamera2"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        <StackPanel x:Name="PlaceholderCam2"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📷" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Camera 2 대기 중..." FontSize="14"
                                       Foreground="#94A3B8" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</mah:MetroWindow>
