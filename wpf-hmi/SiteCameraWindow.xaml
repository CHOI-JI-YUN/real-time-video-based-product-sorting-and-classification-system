<mah:MetroWindow x:Class="VisiPickHMI.SiteCameraWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        Title="현장 CCTV  |  VisiPick"
        TitleCharacterCasing="Normal"
        GlowBrush="#3B82F6"
        NonActiveGlowBrush="#1E2D4A"
        WindowTitleBrush="#0B1120"
        NonActiveWindowTitleBrush="#0B1120"
        TitleBarHeight="32"
        TitleForeground="#94A3B8"
        Width="960" Height="640"
        MinWidth="640" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="#0B1120">

    <Border Margin="10"
            Background="#151F35"
            BorderBrush="#1E2D4A"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══ 헤더 ══ -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="4" Height="14" CornerRadius="2" Margin="0,0,8,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#3B82F6" Offset="0"/>
                                <GradientStop Color="#22D3EE" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="📹 전체 현장 (CCTV)" FontSize="13" FontWeight="SemiBold"
                               Foreground="#94A3B8" VerticalAlignment="Center"/>
                    <Ellipse x:Name="DotLive" Width="7" Height="7" Fill="#FF3B30"
                             Margin="10,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LiveLabel" Text="OFFLINE" FontSize="9" Foreground="#FF3B30"
                               Margin="4,0,0,0" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 줌 컨트롤 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtZoomLevel" Text="100%" FontSize="11" Foreground="#5A7090"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button x:Name="BtnZoomOut" Content="−" Cursor="Hand"
                            Width="30" Height="26" FontSize="16" FontWeight="Bold"
                            Foreground="#94A3B8" Background="#1E2D4A" BorderThickness="0"
                            Click="ZoomOut_Click" ToolTip="축소"/>
                    <Button x:Name="BtnZoomReset" Content="1:1" Cursor="Hand"
                            Width="36" Height="26" FontSize="11"
                            Foreground="#94A3B8" Background="#1E2D4A" BorderThickness="0"
                            Margin="4,0,4,0" Click="ZoomReset_Click" ToolTip="원래 크기"/>
                    <Button x:Name="BtnZoomIn" Content="＋" Cursor="Hand"
                            Width="30" Height="26" FontSize="14" FontWeight="Bold"
                            Foreground="#94A3B8" Background="#1E2D4A" BorderThickness="0"
                            Click="ZoomIn_Click" ToolTip="확대"/>
                </StackPanel>
            </Grid>

            <!-- ══ 영상 ══ -->
            <Border Grid.Row="1" Background="#0A0F1C" CornerRadius="6"
                    BorderBrush="#1E2D4A" BorderThickness="1" ClipToBounds="True">
                <Grid x:Name="ImageContainer" Background="Transparent"
                      MouseWheel="ImgSite_MouseWheel"
                      MouseLeftButtonDown="Image_MouseDown"
                      MouseMove="Image_MouseMove"
                      MouseLeftButtonUp="Image_MouseUp">
                    <Image x:Name="ImgSite"
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="LowQuality"
                           RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                                <TranslateTransform x:Name="ImageTranslate" X="0" Y="0"/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                    <StackPanel x:Name="PlaceholderSite"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📹" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock x:Name="TxtPlaceholder" Text="카메라 연결 중..." FontSize="14"
                                   Foreground="#94A3B8" HorizontalAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</mah:MetroWindow>
