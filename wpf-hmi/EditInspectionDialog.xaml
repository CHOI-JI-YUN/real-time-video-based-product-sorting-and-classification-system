<mah:MetroWindow x:Class="VisiPickHMI.EditInspectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        Title="✏ 검사 결과 수정"
        TitleCharacterCasing="Normal"
        WindowTitleBrush="#0B1120"
        GlowBrush="#3B82F6"
        TitleBarHeight="32"
        TitleForeground="#94A3B8"
        Width="380" Height="420"
        WindowStartupLocation="CenterOwner"
        Background="#0B1120"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="11" Foreground="#64748B" Margin="0,0,0,12">
            <Run Text="ID: "/><Run x:Name="TxtId" FontWeight="Bold" Foreground="#94A3B8"/>
            <Run Text="  |  "/><Run x:Name="TxtTime" Foreground="#94A3B8"/>
        </TextBlock>

        <TextBlock Grid.Row="1" Text="부품 타입" FontSize="10" Foreground="#94A3B8" Margin="0,0,0,3"/>
        <TextBox Grid.Row="2" x:Name="TbComponent" Background="#151F35" Foreground="#E2E8F0"
                 BorderBrush="#1E2D4A" Padding="8,5" FontSize="12" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="3" Text="결과" FontSize="10" Foreground="#94A3B8" Margin="0,0,0,3"/>
        <ComboBox Grid.Row="4" x:Name="CbResult" Background="#151F35" Foreground="#E2E8F0"
                  BorderBrush="#1E2D4A" Padding="6,4" FontSize="12" Margin="0,0,0,10">
            <ComboBoxItem Content="양품"/>
            <ComboBoxItem Content="불량"/>
            <ComboBoxItem Content="PASS"/>
            <ComboBoxItem Content="DEFECT"/>
        </ComboBox>

        <TextBlock Grid.Row="5" Text="불량 유형" FontSize="10" Foreground="#94A3B8" Margin="0,0,0,3"/>
        <ComboBox Grid.Row="6" x:Name="CbDefect" Background="#151F35" Foreground="#E2E8F0"
                  BorderBrush="#1E2D4A" Padding="6,4" FontSize="12" Margin="0,0,0,10">
            <ComboBoxItem Content="—"/>
            <ComboBoxItem Content="파손"/>
            <ComboBoxItem Content="핀휨"/>
        </ComboBox>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="취소" Width="80" Height="32" FontSize="12"
                    Foreground="#94A3B8" Background="#1E2D4A" BorderThickness="0"
                    Cursor="Hand" Margin="0,0,8,0" Click="Cancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="💾 저장" Width="90" Height="32" FontSize="12"
                    Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"
                    Click="Save_Click">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#3B82F6" Offset="0"/>
                        <GradientStop Color="#2563EB" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
