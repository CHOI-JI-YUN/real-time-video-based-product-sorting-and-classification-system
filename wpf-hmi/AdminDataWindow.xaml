<mah:MetroWindow x:Class="VisiPickHMI.AdminDataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        Title="🔧 관리자 데이터 관리"
        TitleCharacterCasing="Normal"
        WindowTitleBrush="#0B1120"
        GlowBrush="#EF5350"
        TitleBarHeight="32"
        TitleForeground="#94A3B8"
        Width="1050" Height="650"
        MinWidth="900" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#0B1120">

    <Window.Resources>
        <Style x:Key="AdminTabBtn" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A2744"/>
                                <Setter Property="Foreground" Value="#22D3EE"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#111B2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AdminBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#1E2D4A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#253456"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource AdminBtn}">
            <Setter Property="Background" Value="#7F1D1D"/>
            <Setter Property="Foreground" Value="#FCA5A5"/>
        </Style>

        <Style x:Key="AdminGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#0D1525"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="RowHeight" Value="28"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#111B2E"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#1E2D4A"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1A2744"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 탭 버튼 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton Content="🔬 검사 결과" GroupName="AdminTab" IsChecked="True"
                         Style="{StaticResource AdminTabBtn}" Click="Tab_Inspection_Click"/>
            <RadioButton Content="📋 이벤트 로그" GroupName="AdminTab" Margin="4,0,0,0"
                         Style="{StaticResource AdminTabBtn}" Click="Tab_Events_Click"/>
            <RadioButton Content="⚙ 시스템 설정" GroupName="AdminTab" Margin="4,0,0,0"
                         Style="{StaticResource AdminTabBtn}" Click="Tab_Settings_Click"/>
            <RadioButton Content="🚗 AGV 운반 기록" GroupName="AdminTab" Margin="4,0,0,0"
                         Style="{StaticResource AdminTabBtn}" Click="Tab_Agv_Click"/>
        </StackPanel>

        <!-- ═══ TAB 1: 검사 결과 관리 ═══ -->
        <Grid x:Name="PanelInspection" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="검사 결과 관리" FontSize="13" FontWeight="SemiBold"
                           Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock x:Name="TxtInspCount" FontSize="11" Foreground="#64748B"
                           VerticalAlignment="Center" Margin="0,0,20,0"/>
                <Button Content="✏ 선택 항목 수정" Style="{StaticResource AdminBtn}" Click="EditInspection_Click" Margin="0,0,6,0"/>
                <Button Content="🗑 선택 항목 삭제" Style="{StaticResource DangerBtn}" Click="DeleteInspection_Click" Margin="0,0,6,0"/>
                <Button Content="🔄 새로고침" Style="{StaticResource AdminBtn}" Click="RefreshInspection_Click"/>
            </StackPanel>

            <DataGrid Grid.Row="1" x:Name="InspGrid" Style="{StaticResource AdminGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="시간" Binding="{Binding Timestamp}" Width="170" FontFamily="Consolas"/>
                    <DataGridTextColumn Header="부품" Binding="{Binding ComponentType}" Width="*"/>
                    <DataGridTextColumn Header="DefectCode" Binding="{Binding DefectCode}" Width="100"/>
                    <DataGridTextColumn Header="불량유형" Binding="{Binding DefectTypeDisplay}" Width="80"/>
                    <DataGridTemplateColumn Header="결과" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ResultGradeDisplay}" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#66BB6A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Result}" Value="DEFECT">
                                                    <Setter Property="Foreground" Value="#EF5350"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Result}" Value="불량">
                                                    <Setter Property="Foreground" Value="#EF5350"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- ═══ TAB 2: 이벤트 로그 관리 ═══ -->
        <Grid x:Name="PanelEvents" Grid.Row="1" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="이벤트 로그 관리" FontSize="13" FontWeight="SemiBold"
                           Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock x:Name="TxtEventCount" FontSize="11" Foreground="#64748B"
                           VerticalAlignment="Center" Margin="0,0,20,0"/>
                <Button Content="🗑 선택 삭제" Style="{StaticResource DangerBtn}" Click="DeleteEvent_Click" Margin="0,0,6,0"/>
                <Button Content="📅 날짜별 일괄 삭제" Style="{StaticResource DangerBtn}" Click="DeleteEventsByDate_Click" Margin="0,0,6,0"/>
                <Button Content="⚠ 전체 삭제" Style="{StaticResource DangerBtn}" Click="DeleteAllEvents_Click" Margin="0,0,6,0"/>
                <Button Content="🔄 새로고침" Style="{StaticResource AdminBtn}" Click="RefreshEvents_Click"/>
            </StackPanel>

            <DataGrid Grid.Row="1" x:Name="EventGrid" Style="{StaticResource AdminGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="시간" Binding="{Binding Timestamp}" Width="155" FontFamily="Consolas"/>
                    <DataGridTextColumn Header="장비" Binding="{Binding Source}" Width="80"/>
                    <DataGridTextColumn Header="유형" Binding="{Binding EventType}" Width="70"/>
                    <DataGridTextColumn Header="메시지" Binding="{Binding Message}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- ═══ TAB 3: 시스템 설정 ═══ -->
        <Grid x:Name="PanelSettings" Grid.Row="1" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="시스템 설정값 관리" FontSize="13" FontWeight="SemiBold"
                           Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="더블클릭으로 값을 수정합니다" FontSize="10" Foreground="#64748B"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <DataGrid Grid.Row="1" x:Name="SettingsGrid" Style="{StaticResource AdminGrid}"
                      IsReadOnly="False" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="키" Binding="{Binding Key}" Width="160" IsReadOnly="True" FontFamily="Consolas"/>
                    <DataGridTextColumn Header="카테고리" Binding="{Binding Category}" Width="80" IsReadOnly="True"/>
                    <DataGridTextColumn Header="값" Binding="{Binding Value}" Width="100"
                                        Foreground="#22D3EE" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="설명" Binding="{Binding Description}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="수정 시간" Binding="{Binding UpdatedAt}" Width="145" IsReadOnly="True" FontFamily="Consolas"/>
                    <DataGridTextColumn Header="수정자" Binding="{Binding UpdatedBy}" Width="70" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="💾 변경사항 저장" Click="SaveSettings_Click" Padding="14,6" FontSize="12"
                        Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3B82F6" Offset="0"/>
                            <GradientStop Color="#2563EB" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══ TAB 4: AGV 운반 기록 관리 ═══ -->
        <Grid x:Name="PanelAgv" Grid.Row="1" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="AGV 운반 기록 기록" FontSize="13" FontWeight="SemiBold"
                           Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock x:Name="TxtAgvCount" FontSize="11" Foreground="#64748B"
                           VerticalAlignment="Center" Margin="0,0,20,0"/>
                <Button Content="✏ 상태 수정" Style="{StaticResource AdminBtn}" Click="EditMission_Click" Margin="0,0,6,0"/>
                <Button Content="🗑 선택 삭제" Style="{StaticResource DangerBtn}" Click="DeleteMission_Click" Margin="0,0,6,0"/>
                <Button Content="🔄 새로고침" Style="{StaticResource AdminBtn}" Click="RefreshMissions_Click"/>
            </StackPanel>

            <DataGrid Grid.Row="1" x:Name="AgvGrid" Style="{StaticResource AdminGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="AGV" Binding="{Binding AgvId}" Width="50"/>
                    <DataGridTextColumn Header="출발" Binding="{Binding StartTime}" Width="150" FontFamily="Consolas"/>
                    <DataGridTextColumn Header="도착" Binding="{Binding EndTime}" Width="150" FontFamily="Consolas"/>
                    <DataGridTextColumn Header="출발지" Binding="{Binding Source}" Width="90"/>
                    <DataGridTextColumn Header="목적지" Binding="{Binding Destination}" Width="90"/>
                    <DataGridTextColumn Header="트레이" Binding="{Binding TrayClass}" Width="55"/>
                    <DataGridTextColumn Header="수량" Binding="{Binding ItemCount}" Width="50"/>
                    <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</mah:MetroWindow>
