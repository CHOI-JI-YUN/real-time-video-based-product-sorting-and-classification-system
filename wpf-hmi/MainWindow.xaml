<mah:MetroWindow x:Class="VisiPickHMI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:VisiPickHMI"
        xmlns:vm="clr-namespace:VisiPickHMI.ViewModels"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="VisiPick V6.2 — Smart Factory HMI"
        TitleCharacterCasing="Normal"
        GlowBrush="#3B82F6"
        NonActiveGlowBrush="#1E2D4A"
        WindowTitleBrush="#0B1120"
        NonActiveWindowTitleBrush="#0B1120"
        TitleBarHeight="32"
        ShowTitleBar="True"
        WindowState="Maximized"
        TitleForeground="#94A3B8"
        Width="1366" Height="768"
        MinWidth="1280" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="#0B1120">

    <!-- ═══ RESOURCES ═══ -->
    <Window.Resources>

        <!-- Converters -->
        <local:NullToVisibleConverter x:Key="NullToVisibleConverter"/>
        <local:CountToBarWidth x:Key="CountToBarWidth"/>
        <local:CountToBarHeight x:Key="CountToBarHeight"/>

        <!-- 색상 팔레트 -->
        <Color x:Key="NavyDark">#0B1120</Color>
        <Color x:Key="NavyMid">#111B2E</Color>
        <Color x:Key="NavyCard">#151F35</Color>
        <Color x:Key="NavyBorder">#1E2D4A</Color>
        <Color x:Key="AccentBlue">#3B82F6</Color>
        <Color x:Key="AccentCyan">#22D3EE</Color>
        <Color x:Key="TextPrimary">#E2E8F0</Color>
        <Color x:Key="TextSecondary">#94A3B8</Color>
        <Color x:Key="GreenOk">#00E676</Color>
        <Color x:Key="YellowWarn">#FFD600</Color>
        <Color x:Key="RedAlert">#FF3B30</Color>

        <SolidColorBrush x:Key="BrNavyDark" Color="{StaticResource NavyDark}"/>
        <SolidColorBrush x:Key="BrNavyMid" Color="{StaticResource NavyMid}"/>
        <SolidColorBrush x:Key="BrNavyCard" Color="{StaticResource NavyCard}"/>
        <SolidColorBrush x:Key="BrNavyBorder" Color="{StaticResource NavyBorder}"/>
        <SolidColorBrush x:Key="BrAccent" Color="{StaticResource AccentBlue}"/>
        <SolidColorBrush x:Key="BrAccentCyan" Color="{StaticResource AccentCyan}"/>
        <SolidColorBrush x:Key="BrText" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="BrTextSec" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="BrGreen" Color="{StaticResource GreenOk}"/>
        <SolidColorBrush x:Key="BrYellow" Color="{StaticResource YellowWarn}"/>
        <SolidColorBrush x:Key="BrRed" Color="{StaticResource RedAlert}"/>

        <!-- 카드 스타일 -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrNavyCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrNavyBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="12" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 섹션 헤더 -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BrTextSec}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- 제어 버튼 기본 스타일 -->
        <Style x:Key="CtrlBtn" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource BrText}"/>
            <Setter Property="Background" Value="{StaticResource BrNavyBorder}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                BorderBrush="{StaticResource BrNavyBorder}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#253456"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A2744"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 강조 버튼 (시작) -->
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource CtrlBtn}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#3B82F6" Offset="0"/>
                        <GradientStop Color="#2563EB" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 비상정지 버튼 -->
        <Style x:Key="EmergencyBtn" TargetType="Button" BasedOn="{StaticResource CtrlBtn}">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- 미니 레이블 -->
        <Style x:Key="MiniLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource BrTextSec}"/>
        </Style>

        <!-- 값 텍스트 -->
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BrText}"/>
        </Style>

        <!-- 큰 숫자 -->
        <Style x:Key="BigNumber" TargetType="TextBlock">
            <Setter Property="FontSize" Value="36"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource BrAccentCyan}"/>
        </Style>

        <!-- Slider 스타일 -->
        <Style x:Key="NavySlider" TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource BrAccent}"/>
            <Setter Property="Minimum" Value="5"/>
            <Setter Property="Maximum" Value="30"/>
            <Setter Property="TickFrequency" Value="1"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
        </Style>

        <!-- ═══ 탭 버튼 스타일 ═══ -->
        <Style x:Key="TabBtn" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource BrTextSec}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#253456"/>
                                <Setter Property="Foreground" Value="{StaticResource BrAccentCyan}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A2744"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ═══ MAIN LAYOUT ═══ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <!-- 상단 상태바 -->
            <RowDefinition Height="*"/>
            <!-- 4분할 대시보드 -->
            <RowDefinition Height="56"/>
            <!-- 하단 제어바 -->
        </Grid.RowDefinitions>

        <!-- ╔══════════════════════════════════════╗ -->
        <!-- ║         상단 상태바 (Row 0)            ║ -->
        <!-- ╚══════════════════════════════════════╝ -->
        <Border Grid.Row="0" Background="{StaticResource BrNavyMid}"
                BorderBrush="{StaticResource BrNavyBorder}" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 로고 & 제목 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="6" Margin="0,0,10,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3B82F6" Offset="0"/>
                                <GradientStop Color="#22D3EE" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="V" FontSize="13" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="VisiPick" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource BrText}" VerticalAlignment="Center"/>
                    <TextBlock Text="V6.2" FontSize="11" Foreground="{StaticResource BrAccentCyan}"
                               VerticalAlignment="Center" Margin="6,0,0,0" FontWeight="SemiBold"/>
                    <Border Width="1" Background="{StaticResource BrNavyBorder}"
                            Margin="16,10" VerticalAlignment="Stretch"/>
                </StackPanel>

                <!-- 장비 연결 상태 (깜빡이는 dot) -->
                <ItemsControl Grid.Column="1" ItemsSource="{Binding Devices}"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,0,18,0" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Margin="0,0,5,0"
                                         Fill="{Binding StatusColor}"
                                         VerticalAlignment="Center"/>
                                <TextBlock FontSize="11" Foreground="{StaticResource BrTextSec}"
                                           VerticalAlignment="Center"
                                           Text="{Binding Name, Mode=OneWay}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 시간 & 모드 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border CornerRadius="4" Padding="8,3" Margin="0,0,8,0"
                            Background="#1E3A5F">
                        <TextBlock Text="{Binding SystemMode}" FontSize="11"
                                   FontWeight="Bold" Foreground="{StaticResource BrAccentCyan}"/>
                    </Border>
                    <!-- 로그인 사용자 -->
                    <Border CornerRadius="4" Padding="8,3" Margin="0,0,8,0" Background="#111B2E">
                        <TextBlock x:Name="TxtLoggedInUser" FontSize="11"
                                   Foreground="{StaticResource BrTextSec}"/>
                    </Border>
                    <!-- 회원관리 버튼 (Admin만 표시) -->
                    <Button x:Name="BtnUserMgmt" Content="👥 회원관리"
                            Style="{StaticResource CtrlBtn}"
                            Padding="8,3" FontSize="11" Margin="0,0,4,0"
                            Visibility="Collapsed"
                            Click="UserMgmt_Click"/>
                    <!-- 데이터관리 버튼 (Admin만 표시) -->
                    <Button x:Name="BtnDataMgmt" Content="🔧 데이터관리"
                            Style="{StaticResource CtrlBtn}"
                            Padding="8,3" FontSize="11" Margin="0,0,4,0"
                            Visibility="Collapsed"
                            Click="DataMgmt_Click"/>
                    <!-- 로그아웃 -->
                    <Button Content="🚪 로그아웃"
                            Style="{StaticResource CtrlBtn}"
                            Padding="8,3" FontSize="11" Margin="0,0,8,0"
                            Click="Logout_Click"/>
                    <TextBlock Text="{Binding CurrentTime}" FontSize="13"
                               Foreground="{StaticResource BrTextSec}" FontFamily="Consolas"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ╔══════════════════════════════════════╗ -->
        <!-- ║       4분할 대시보드 (Row 1)          ║ -->
        <!-- ╚══════════════════════════════════════╝ -->
        <Grid Grid.Row="1" Margin="10,10,10,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="1.2*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═════════════════════════════════════════════════ -->
            <!-- ① 좌상: 실시간 카메라 영상 (탭 2개: Camera1 / Camera2) -->
            <!-- ═════════════════════════════════════════════════ -->
            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,5,5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 헤더 + 카메라 탭 -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="4" Height="14" CornerRadius="2" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#3B82F6" Offset="0"/>
                                        <GradientStop Color="#22D3EE" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <TextBlock Text="① 실시간 카메라 영상" FontSize="13"
                                       FontWeight="SemiBold" Foreground="{StaticResource BrTextSec}"
                                       VerticalAlignment="Center"/>
                            <Ellipse Width="7" Height="7" Fill="{Binding Devices[0].StatusColor}" Margin="10,0,0,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock FontSize="9"
                                       Margin="4,0,0,0" FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="OFFLINE"/>
                                        <Setter Property="Foreground" Value="#FF3B30"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Devices[0].IsConnected}" Value="True">
                                                <Setter Property="Text" Value="LIVE"/>
                                                <Setter Property="Foreground" Value="#00E676"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- 카메라 탭 버튼 -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <RadioButton Content="📷 Camera 1" GroupName="CamTab" IsChecked="True"
                                         Style="{StaticResource TabBtn}" Click="CameraTab1_Click"/>
                            <RadioButton Content="📷 Camera 2" GroupName="CamTab"
                                         Style="{StaticResource TabBtn}" Margin="4,0,0,0" Click="CameraTab2_Click"/>
                            <RadioButton Content="⊞ 전체 보기" GroupName="CamTab"
                                         Style="{StaticResource TabBtn}" Margin="4,0,0,0" Click="CameraTabDual_Click"/>
                            <Button Content="↗ 별도 창" Style="{StaticResource CtrlBtn}"
                                    Padding="8,4" FontSize="10" Margin="8,0,0,0"
                                    Click="AllCameraWindow_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- 카메라 프레임 영역 (Visibility로 전환) -->
                    <Grid Grid.Row="1">
                        <!-- Camera 1 -->
                        <Border x:Name="Camera1Panel" Background="#0A0F1C" CornerRadius="6"
                                BorderBrush="{StaticResource BrNavyBorder}" BorderThickness="1">
                            <Grid>
                                <Image x:Name="CameraImage1" Source="{Binding CameraFrame1}"
                                       Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <Canvas x:Name="BoundingBoxCanvas" ClipToBounds="True"/>

                                <!-- 트레이 슬롯 오버레이 (우상단 2×2) -->
                                <ItemsControl ItemsSource="{Binding TraySlots}"
                                              HorizontalAlignment="Right" VerticalAlignment="Top"
                                              Margin="0,6,14,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="2" Columns="2"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="52" Height="58" CornerRadius="6" Margin="2"
                                                    Background="{Binding SlotBackground}"
                                                    BorderBrush="{Binding SlotBorderBrush}" BorderThickness="1"
                                                    Opacity="{Binding SlotOpacity}">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <Path Data="{Binding SlotPath}" Stretch="Uniform"
                                                          Width="24" Height="24"
                                                          Fill="{Binding SlotFill}"
                                                          Stroke="{Binding SlotStroke}" StrokeThickness="1.2"
                                                          HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding SlotName}" FontSize="8"
                                                               FontWeight="SemiBold" Foreground="{Binding SlotStroke}"
                                                               HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Visibility="{Binding CameraFrame1, Converter={StaticResource NullToVisibleConverter}}">
                                    <TextBlock Text="📷" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="Camera 1 대기 중..." FontSize="13"
                                               Foreground="{StaticResource BrTextSec}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="OpenCvSharp WriteableBitmap" FontSize="10"
                                               Foreground="#475569" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Camera 2 -->
                        <Border x:Name="Camera2Panel" Background="#0A0F1C" CornerRadius="6"
                                BorderBrush="{StaticResource BrNavyBorder}" BorderThickness="1"
                                Visibility="Collapsed">
                            <Grid>
                                <Image x:Name="CameraImage2" Source="{Binding CameraFrame2}"
                                       Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Visibility="{Binding CameraFrame2, Converter={StaticResource NullToVisibleConverter}}">
                                    <TextBlock Text="📷" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="Camera 2 대기 중..." FontSize="13"
                                               Foreground="{StaticResource BrTextSec}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="보조 카메라 (Eye-in-Hand 등)" FontSize="10"
                                               Foreground="#475569" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Dual (전체 보기) — 좌우 2분할 -->
                        <Grid x:Name="DualCameraPanel" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Dual: Camera 1 -->
                            <Border Grid.Column="0" Background="#0A0F1C" CornerRadius="6"
                                    BorderBrush="{StaticResource BrNavyBorder}" BorderThickness="1">
                                <Grid>
                                    <Image Source="{Binding CameraFrame1}" Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Visibility="{Binding CameraFrame1, Converter={StaticResource NullToVisibleConverter}}">
                                        <TextBlock Text="📷" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="Camera 1 대기 중..." FontSize="11"
                                                   Foreground="{StaticResource BrTextSec}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <!-- 좌측 레이블 -->
                                    <Border Background="#CC0B1120" CornerRadius="4" Padding="6,2"
                                            HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6">
                                        <TextBlock Text="📷 Cam 1" FontSize="9" FontWeight="SemiBold"
                                                   Foreground="#22D3EE"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- 구분선 -->
                            <Border Grid.Column="1" Background="{StaticResource BrNavyBorder}"/>

                            <!-- Dual: Camera 2 -->
                            <Border Grid.Column="2" Background="#0A0F1C" CornerRadius="6"
                                    BorderBrush="{StaticResource BrNavyBorder}" BorderThickness="1">
                                <Grid>
                                    <Image Source="{Binding CameraFrame2}" Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Visibility="{Binding CameraFrame2, Converter={StaticResource NullToVisibleConverter}}">
                                        <TextBlock Text="📷" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="Camera 2 대기 중..." FontSize="11"
                                                   Foreground="{StaticResource BrTextSec}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <!-- 우측 레이블 -->
                                    <Border Background="#CC0B1120" CornerRadius="4" Padding="6,2"
                                            HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6">
                                        <TextBlock Text="📷 Cam 2" FontSize="9" FontWeight="SemiBold"
                                                   Foreground="#22D3EE"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- 하단 검출 정보 카드 -->
                    <Border Grid.Row="2" Background="#111B2E" CornerRadius="6" Padding="12,8" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Component" Style="{StaticResource MiniLabel}"/>
                                <TextBlock Text="{Binding LastComponent}" Style="{StaticResource ValueText}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Class" Style="{StaticResource MiniLabel}"/>
                                <TextBlock Text="{Binding LastClass}" Style="{StaticResource ValueText}"
                                           Foreground="{StaticResource BrAccentCyan}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Confidence" Style="{StaticResource MiniLabel}"/>
                                <TextBlock Text="{Binding LastConfidence, StringFormat={}{0:F2}}"
                                           Style="{StaticResource ValueText}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Result" Style="{StaticResource MiniLabel}"/>
                                <TextBlock Text="{Binding LastResultDisplay}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource ValueText}">
                                            <Setter Property="Foreground" Value="{StaticResource BrGreen}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LastResult}" Value="DEFECT">
                                                    <Setter Property="Foreground" Value="#EF5350"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding LastResult}" Value="불량">
                                                    <Setter Property="Foreground" Value="#EF5350"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Gate" Style="{StaticResource MiniLabel}"/>
                                <TextBlock Text="{Binding LastGate}" Style="{StaticResource ValueText}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ═════════════════════════════════════════════════════ -->
            <!-- ② 우상: 분류 현황 / 불량 현황 탭                        -->
            <!-- ═════════════════════════════════════════════════════ -->
            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardBorder}" Margin="5,0,0,5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 헤더 + 탭 -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border Width="4" Height="14" CornerRadius="2" Margin="0,0,8,0"
                                    Background="{StaticResource BrAccentCyan}"/>
                            <TextBlock Text="② 분류 · 불량 현황" FontSize="13"
                                       FontWeight="SemiBold" Foreground="{StaticResource BrTextSec}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <RadioButton Content="📊 분류 현황" GroupName="StatsTab" IsChecked="True"
                                         Style="{StaticResource TabBtn}" Click="StatsTab_Classification_Click"/>
                            <RadioButton Content="🔴 불량 현황" GroupName="StatsTab"
                                         Style="{StaticResource TabBtn}" Margin="4,0,0,0" Click="StatsTab_Defect_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- ──── TAB A: 분류 현황 (기존) ──── -->
                    <Grid x:Name="ClassificationPanel" Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 상단 요약 카드 -->
                        <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,12">
                            <Border Background="#111B2E" CornerRadius="6" Padding="10,8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="총 검사" Style="{StaticResource MiniLabel}"/>
                                    <TextBlock Text="{Binding Summary.TotalCount}" FontSize="24"
                                               FontWeight="Bold" Foreground="{StaticResource BrText}"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#2C1010" CornerRadius="6" Padding="10,8" Margin="4,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="불량" Style="{StaticResource MiniLabel}" Foreground="#EF5350"/>
                                    <TextBlock Text="{Binding Summary.DefectCount}" FontSize="24"
                                               FontWeight="Bold" Foreground="#EF5350"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#0D2818" CornerRadius="6" Padding="10,8" Margin="4,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="양품" Style="{StaticResource MiniLabel}" Foreground="#66BB6A"/>
                                    <TextBlock Text="{Binding Summary.PassCount}" FontSize="24"
                                               FontWeight="Bold" Foreground="#66BB6A"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- 양품률 + 클래스별 바 -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                                <TextBlock Text="양품률" FontSize="11" Foreground="{StaticResource BrTextSec}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Style="{StaticResource BigNumber}" HorizontalAlignment="Center">
                                    <Run Text="{Binding Summary.YieldRateText, Mode=OneWay}"/><Run Text="%" FontSize="18"/>
                                </TextBlock>
                                <TextBlock HorizontalAlignment="Center" Margin="0,2,0,0">
                                    <Run Text="사이클 " FontSize="10" Foreground="{StaticResource BrTextSec}"/>
                                    <Run Text="{Binding CurrentCycle, Mode=OneWay}" FontSize="11"
                                         FontWeight="Bold" Foreground="{StaticResource BrText}"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <!-- A: IC칩 -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontSize="12" Foreground="{StaticResource BrTextSec}" VerticalAlignment="Center">
                                        <Run Text="A" FontWeight="Bold" Foreground="#60A5FA"/>
                                        <Run Text=" IC칩"/>
                                    </TextBlock>
                                    <Border Grid.Column="1" Height="18" CornerRadius="4" Background="#1A2744">
                                        <Border CornerRadius="4" HorizontalAlignment="Left"
                                                Width="{Binding Summary.ClassACount, Converter={StaticResource CountToBarWidth}}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#3B82F6" Offset="0"/>
                                                    <GradientStop Color="#60A5FA" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding Summary.ClassACount, StringFormat={}{0}개}"
                                               FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource BrText}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <!-- B: 터미널 블록 -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontSize="12" Foreground="{StaticResource BrTextSec}" VerticalAlignment="Center">
                                        <Run Text="B" FontWeight="Bold" Foreground="#34D399"/>
                                        <Run Text=" 터미널 블록"/>
                                    </TextBlock>
                                    <Border Grid.Column="1" Height="18" CornerRadius="4" Background="#1A2744">
                                        <Border CornerRadius="4" HorizontalAlignment="Left"
                                                Width="{Binding Summary.ClassBCount, Converter={StaticResource CountToBarWidth}}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#059669" Offset="0"/>
                                                    <GradientStop Color="#34D399" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding Summary.ClassBCount, StringFormat={}{0}개}"
                                               FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource BrText}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <!-- C: 방열판 -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontSize="12" Foreground="{StaticResource BrTextSec}" VerticalAlignment="Center">
                                        <Run Text="C" FontWeight="Bold" Foreground="#FBBF24"/>
                                        <Run Text=" 방열판"/>
                                    </TextBlock>
                                    <Border Grid.Column="1" Height="18" CornerRadius="4" Background="#1A2744">
                                        <Border CornerRadius="4" HorizontalAlignment="Left"
                                                Width="{Binding Summary.ClassCCount, Converter={StaticResource CountToBarWidth}}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#D97706" Offset="0"/>
                                                    <GradientStop Color="#FBBF24" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding Summary.ClassCCount, StringFormat={}{0}개}"
                                               FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource BrText}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <!-- D: 커패시터 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontSize="12" Foreground="{StaticResource BrTextSec}" VerticalAlignment="Center">
                                        <Run Text="D" FontWeight="Bold" Foreground="#C084FC"/>
                                        <Run Text=" 커패시터"/>
                                    </TextBlock>
                                    <Border Grid.Column="1" Height="18" CornerRadius="4" Background="#1A2744">
                                        <Border CornerRadius="4" HorizontalAlignment="Left"
                                                Width="{Binding Summary.ClassDCount, Converter={StaticResource CountToBarWidth}}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#7C3AED" Offset="0"/>
                                                    <GradientStop Color="#C084FC" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding Summary.ClassDCount, StringFormat={}{0}개}"
                                               FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource BrText}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- LiveCharts2: 시간대별 생산 추이 -->
                        <Border Grid.Row="2" Background="#0E1726" CornerRadius="6" Padding="8,6" Margin="0,10,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="시간대별 생산 추이" FontSize="10"
                                           Foreground="{StaticResource BrTextSec}" Margin="4,0,0,4"/>
                                <lvc:CartesianChart Grid.Row="1"
                                                    Series="{Binding ProductionSeries}"
                                                    XAxes="{Binding ProductionXAxes}"
                                                    YAxes="{Binding ProductionYAxes}"
                                                    TooltipPosition="Top"
                                                    MinHeight="90"
                                                    AnimationsSpeed="00:00:00.300"
                                                    Background="Transparent"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ──── TAB B: 불량 현황 (Flask 통계 대체) ──── -->
                    <Grid x:Name="DefectPanel" Grid.Row="1" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- KPI 4카드 -->
                        <UniformGrid Grid.Row="0" Columns="2" Margin="0,0,0,12">
                            <Border Background="#2C1010" CornerRadius="6" Padding="10,8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="불량률" Style="{StaticResource MiniLabel}" Foreground="#FF8A80"/>
                                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="#FF8A80">
                                        <Run Text="{Binding DefectRateText, Mode=OneWay}"/><Run Text="%" FontSize="14"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border Background="#111B2E" CornerRadius="6" Padding="10,8" Margin="4,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="총 검사" Style="{StaticResource MiniLabel}"/>
                                    <TextBlock Text="{Binding Summary.TotalCount}" FontSize="24"
                                               FontWeight="Bold" Foreground="{StaticResource BrText}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- 클래스별 불량 카드 -->
                        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
                            <Border Background="#111B2E" CornerRadius="6" Padding="10,6" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="#60A5FA" FontWeight="SemiBold">
                                        <Run Text="A"/><Run Text=" IC칩 불량" Foreground="{StaticResource BrTextSec}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding DefectClassA}" FontSize="20" FontWeight="Bold"
                                               Foreground="#EF5350" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#111B2E" CornerRadius="6" Padding="10,6" Margin="4,0,4,0">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="#34D399" FontWeight="SemiBold">
                                        <Run Text="B"/><Run Text=" 터미널 불량" Foreground="{StaticResource BrTextSec}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding DefectClassB}" FontSize="20" FontWeight="Bold"
                                               Foreground="#EF5350" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#111B2E" CornerRadius="6" Padding="10,6" Margin="4,0,4,0">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="#FBBF24" FontWeight="SemiBold">
                                        <Run Text="C"/><Run Text=" 방열판 불량" Foreground="{StaticResource BrTextSec}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding DefectClassC}" FontSize="20" FontWeight="Bold"
                                               Foreground="#EF5350" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#111B2E" CornerRadius="6" Padding="10,6" Margin="4,0,0,0">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="#C084FC" FontWeight="SemiBold">
                                        <Run Text="D"/><Run Text=" 커패시터 불량" Foreground="{StaticResource BrTextSec}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding DefectClassD}" FontSize="20" FontWeight="Bold"
                                               Foreground="#EF5350" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- 부품별 불량 분포 (도넛 차트 4개) -->
                        <Border Grid.Row="2" Background="#0E1726" CornerRadius="6" Padding="12,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- 헤더 + 범례 -->
                                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                        <Border Width="3" Height="12" CornerRadius="2" Background="#EF5350" Margin="0,0,8,0"/>
                                        <TextBlock Text="부품별 불량 분포" FontSize="11"
                                                   FontWeight="SemiBold" Foreground="{StaticResource BrTextSec}"/>
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Border Width="8" Height="8" CornerRadius="2" Background="#C48B9F" Margin="0,0,5,0"/>
                                        <TextBlock Text="파손" FontSize="10" Foreground="#94A3B8" Margin="0,0,14,0" VerticalAlignment="Center"/>
                                        <Border Width="8" Height="8" CornerRadius="2" Background="#6B9AB8" Margin="0,0,5,0"/>
                                        <TextBlock Text="핀휨" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                                <!-- 4개 도넛 차트 -->
                                <UniformGrid Grid.Row="1" Columns="4">
                                    <Border Background="#0A101E" CornerRadius="8" Padding="6" Margin="0,0,4,0"
                                            BorderBrush="#1A2744" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" FontSize="10" FontWeight="SemiBold" Margin="0,2,0,2">
                                                <Run Text="A " Foreground="#60A5FA" FontWeight="Bold"/><Run Text="IC칩" Foreground="#7A8BA8"/>
                                            </TextBlock>
                                            <Canvas x:Name="DonutA" Grid.Row="1" MinHeight="90" ClipToBounds="True"
                                                    Loaded="DonutChart_Loaded" Tag="A"/>
                                            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,2,0,4">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Border Width="6" Height="6" CornerRadius="1" Background="#C48B9F" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock FontSize="9" Foreground="#8892A6" Margin="0,0,10,0">
                                                        <Run Text="파손 "/><Run x:Name="TxtA_Crack" Text="0" FontWeight="Bold" Foreground="#CBD5E1"/>
                                                    </TextBlock>
                                                    <Border Width="6" Height="6" CornerRadius="1" Background="#6B9AB8" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock FontSize="9" Foreground="#8892A6">
                                                        <Run Text="핀휨 "/><Run x:Name="TxtA_BentPin" Text="0" FontWeight="Bold" Foreground="#CBD5E1"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Background="#0A101E" CornerRadius="8" Padding="6" Margin="2,0,2,0"
                                            BorderBrush="#1A2744" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" FontSize="10" FontWeight="SemiBold" Margin="0,2,0,2">
                                                <Run Text="B " Foreground="#34D399" FontWeight="Bold"/><Run Text="터미널 블록" Foreground="#7A8BA8"/>
                                            </TextBlock>
                                            <Canvas x:Name="DonutB" Grid.Row="1" MinHeight="90" ClipToBounds="True"
                                                    Loaded="DonutChart_Loaded" Tag="B"/>
                                            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,2,0,4">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Border Width="6" Height="6" CornerRadius="1" Background="#6B9AB8" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock FontSize="9" Foreground="#8892A6">
                                                        <Run Text="핀휨 "/><Run x:Name="TxtB_BentPin" Text="0" FontWeight="Bold" Foreground="#CBD5E1"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Background="#0A101E" CornerRadius="8" Padding="6" Margin="2,0,2,0"
                                            BorderBrush="#1A2744" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" FontSize="10" FontWeight="SemiBold" Margin="0,2,0,2">
                                                <Run Text="C " Foreground="#FBBF24" FontWeight="Bold"/><Run Text="방열판" Foreground="#7A8BA8"/>
                                            </TextBlock>
                                            <Canvas x:Name="DonutC" Grid.Row="1" MinHeight="90" ClipToBounds="True"
                                                    Loaded="DonutChart_Loaded" Tag="C"/>
                                            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,2,0,4">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Border Width="6" Height="6" CornerRadius="1" Background="#C48B9F" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock FontSize="9" Foreground="#8892A6">
                                                        <Run Text="파손 "/><Run x:Name="TxtC_Crack" Text="0" FontWeight="Bold" Foreground="#CBD5E1"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Background="#0A101E" CornerRadius="8" Padding="6" Margin="4,0,0,0"
                                            BorderBrush="#1A2744" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" FontSize="10" FontWeight="SemiBold" Margin="0,2,0,2">
                                                <Run Text="D " Foreground="#C084FC" FontWeight="Bold"/><Run Text="커패시터" Foreground="#7A8BA8"/>
                                            </TextBlock>
                                            <Canvas x:Name="DonutD" Grid.Row="1" MinHeight="90" ClipToBounds="True"
                                                    Loaded="DonutChart_Loaded" Tag="D"/>
                                            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,2,0,4">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Border Width="6" Height="6" CornerRadius="1" Background="#C48B9F" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock FontSize="9" Foreground="#8892A6">
                                                        <Run Text="파손 "/><Run x:Name="TxtD_Crack" Text="0" FontWeight="Bold" Foreground="#CBD5E1"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </UniformGrid>
                            </Grid>
                        </Border>
                        <!-- 최근 불량 리스트 (간략) -->
                        <Border Grid.Row="3" Background="#111B2E" CornerRadius="6" Padding="8,6" Margin="0,8,0,0"
                                Height="76">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="최근 불량 이력" FontSize="10"
                                           Foreground="{StaticResource BrTextSec}" Margin="0,0,0,4"/>
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding RecentDefects}"
                                              ClipToBounds="True" Height="48">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Height="16">
                                                <TextBlock FontSize="9" FontFamily="Consolas" Foreground="{StaticResource BrTextSec}"
                                                           Text="{Binding Timestamp, Mode=OneWay}"/>
                                                <TextBlock Text=" " FontSize="10"/>
                                                <TextBlock FontSize="10" Foreground="{StaticResource BrText}"
                                                           Text="{Binding ComponentType, Mode=OneWay}"/>
                                                <TextBlock Text=" " FontSize="10"/>
                                                <TextBlock FontSize="10" FontWeight="SemiBold"
                                                           Text="{Binding ResultGradeDisplay, Mode=OneWay}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#EF5350"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Result}" Value="불량">
                                                                    <Setter Property="Foreground" Value="#EF5350"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text=" " FontSize="10"/>
                                                <TextBlock FontSize="9" Foreground="#8892A6"
                                                           Text="{Binding DefectCode, Mode=OneWay}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- ③ 좌하: AGV 상태 (기존 유지) -->
            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,5,5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Width="4" Height="14" CornerRadius="2" Margin="0,0,8,0"
                                Background="#FBBF24"/>
                        <TextBlock Text="③ AGV 상태" FontSize="13"
                                   FontWeight="SemiBold" Foreground="{StaticResource BrTextSec}"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#0A0F1C" CornerRadius="6"
                                BorderBrush="{StaticResource BrNavyBorder}" BorderThickness="1">
                            <Canvas x:Name="AgvMapCanvas" ClipToBounds="True" Loaded="AgvMapCanvas_Loaded"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <Border Background="#111B2E" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Ellipse Width="8" Height="8" Fill="#00E676" Margin="0,0,6,0"/>
                                        <TextBlock Text="AGV 1호기" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrText}"/>
                                    </StackPanel>
                                    <TextBlock FontSize="11" Foreground="{StaticResource BrTextSec}" Margin="0,2,0,0">
                                        <Run Text="상태: "/><Run Text="{Binding AgvList[0].State, Mode=OneWay}"
                                             Foreground="{StaticResource BrAccentCyan}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="{StaticResource BrTextSec}" Margin="0,2,0,0">
                                        <Run Text="노드: "/><Run Text="{Binding AgvList[0].Node, Mode=OneWay}"
                                             Foreground="{StaticResource BrText}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="{StaticResource BrTextSec}" Margin="0,2,0,0">
                                        <Run Text="동작: "/><Run Text="{Binding AgvList[0].NextAction, Mode=OneWay}"
                                             Foreground="{StaticResource BrText}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border Background="#111B2E" CornerRadius="6" Padding="10,8">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Ellipse Width="8" Height="8" Fill="#FFD600" Margin="0,0,6,0"/>
                                        <TextBlock Text="AGV 2호기" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrText}"/>
                                    </StackPanel>
                                    <TextBlock FontSize="11" Foreground="{StaticResource BrTextSec}" Margin="0,2,0,0">
                                        <Run Text="상태: "/><Run Text="{Binding AgvList[1].State, Mode=OneWay}"
                                             Foreground="#FFD600" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="{StaticResource BrTextSec}" Margin="0,2,0,0">
                                        <Run Text="노드: "/><Run Text="{Binding AgvList[1].Node, Mode=OneWay}"
                                             Foreground="{StaticResource BrText}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="{StaticResource BrTextSec}" Margin="0,2,0,0">
                                        <Run Text="동작: "/><Run Text="{Binding AgvList[1].NextAction, Mode=OneWay}"
                                             Foreground="{StaticResource BrText}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <!-- 홈 베이 상태 (공용) -->
                            <Border Background="#111B2E" CornerRadius="6" Padding="10,8" Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="홈 베이" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrTextSec}" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="22" Height="16" CornerRadius="3" Margin="0,0,4,0"
                                                Background="{Binding AgvList[0].Home1Free, Mode=OneWay, Converter={x:Static local:BoolToHomeBayBrushConverter.Instance}}">
                                            <TextBlock Text="H1" FontSize="8" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Width="22" Height="16" CornerRadius="3" Margin="0,0,4,0"
                                                Background="{Binding AgvList[0].Home2Free, Mode=OneWay, Converter={x:Static local:BoolToHomeBayBrushConverter.Instance}}">
                                            <TextBlock Text="H2" FontSize="8" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Width="22" Height="16" CornerRadius="3"
                                                Background="{Binding AgvList[0].Home3Free, Mode=OneWay, Converter={x:Static local:BoolToHomeBayBrushConverter.Instance}}">
                                            <TextBlock Text="H3" FontSize="8" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ④ 우하: 이벤트 로그 (기존 유지) -->
            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardBorder}" Margin="5,5,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Width="4" Height="14" CornerRadius="2" Margin="0,0,8,0"
                                Background="#EF5350"/>
                        <TextBlock Text="④ 이벤트 로그" FontSize="13"
                                   FontWeight="SemiBold" Foreground="{StaticResource BrTextSec}"/>
                        <TextBlock Margin="10,0,0,0" FontSize="11" Foreground="{StaticResource BrTextSec}"
                                   VerticalAlignment="Center">
                            <Run Text="{Binding EventLog.Count, Mode=OneWay}"/>
                            <Run Text="건"/>
                        </TextBlock>
                    </StackPanel>

                    <DataGrid Grid.Row="1" x:Name="LogGrid"
                              ItemsSource="{Binding EventLog}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              SelectionMode="Single"
                              Background="Transparent"
                              BorderThickness="0"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#0D1525"
                              Foreground="{StaticResource BrText}"
                              FontSize="11"
                              RowHeight="26">

                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#111B2E"/>
                                <Setter Property="Foreground" Value="{StaticResource BrTextSec}"/>
                                <Setter Property="FontSize" Value="10"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BrNavyBorder}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#1A2744"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="8,2"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="시간" Binding="{Binding Timestamp}" Width="140"
                                                FontFamily="Consolas"/>
                            <DataGridTextColumn Header="장비" Binding="{Binding Source}" Width="75"/>
                            <DataGridTemplateColumn Header="유형" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="3" Padding="5,1"
                                                HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding EventType}" Value="INFO">
                                                            <Setter Property="Background" Value="#132544"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding EventType}" Value="WARNING">
                                                            <Setter Property="Background" Value="#3D3010"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding EventType}" Value="ERROR">
                                                            <Setter Property="Background" Value="#3D1010"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding EventType}" FontSize="9"
                                                       FontWeight="Bold" Foreground="{Binding EventColor}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="메시지" Binding="{Binding Message}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0"
                                HorizontalAlignment="Right">
                        <CheckBox Content="자동 스크롤" IsChecked="{Binding AutoScroll}"
                                  Foreground="{StaticResource BrTextSec}" FontSize="11"
                                  Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <Button Content="📂 날짜별 불러오기" Style="{StaticResource CtrlBtn}"
                                Padding="10,4" FontSize="11" Margin="0,0,6,0" Click="LoadLogsByDate_Click"/>
                        <Button Content="📄 CSV 내보내기" Style="{StaticResource CtrlBtn}"
                                Padding="10,4" FontSize="11" Click="ExportCsv_Click"/>
                        <Button x:Name="BtnClearLogs" Content="🗑 초기화" Style="{StaticResource CtrlBtn}"
                                Padding="10,4" FontSize="11" Margin="6,0,0,0" Click="ClearLogs_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ╔══════════════════════════════════════╗ -->
        <!-- ║         하단 제어바 (Row 2)            ║ -->
        <!-- ╚══════════════════════════════════════╝ -->
        <Border Grid.Row="2" Background="{StaticResource BrNavyMid}"
                BorderBrush="{StaticResource BrNavyBorder}" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="▶ 컨베이어 시작" Style="{StaticResource AccentBtn}" Click="ConveyorStart_Click"
                            Margin="0,0,6,0"/>
                    <Button Content="⏹ 컨베이어 정지" Style="{StaticResource CtrlBtn}" Click="ConveyorStop_Click"
                            Margin="0,0,6,0"/>
                    <Button x:Name="BtnReset" Content="🔄 리셋" Style="{StaticResource CtrlBtn}" Click="Reset_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontSize="11" Foreground="{StaticResource BrTextSec}"
                               VerticalAlignment="Center" Margin="0,0,6,0" Text="사이클"/>
                    <Border Background="#1A2744" CornerRadius="4" Padding="8,3">
                        <TextBlock FontSize="13" FontFamily="Consolas" Foreground="{StaticResource BrText}">
                            <Run Text="{Binding CurrentCycleText, Mode=OneWay}"/>
                        </TextBlock>
                    </Border>

                    <TextBlock FontSize="11" Foreground="{StaticResource BrTextSec}"
                               VerticalAlignment="Center" Margin="14,0,6,0" Text="경과"/>
                    <Border Background="#1A2744" CornerRadius="4" Padding="8,3">
                        <TextBlock Text="{Binding ElapsedTime}" FontSize="13" FontFamily="Consolas"
                                   Foreground="{StaticResource BrAccentCyan}"/>
                    </Border>
                </StackPanel>

                <Border Grid.Column="5" Width="1" Background="{StaticResource BrNavyBorder}"
                        Margin="14,10"/>

                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border CornerRadius="4" Padding="10,3" Margin="0,0,10,0" Background="#111B2E">
                        <TextBlock FontSize="12" VerticalAlignment="Center">
                            <Run Text="상태: " Foreground="{StaticResource BrTextSec}"/>
                            <Run Text="{Binding SystemState, Mode=OneWay}" FontWeight="Bold"
                                 Foreground="{StaticResource BrAccentCyan}"/>
                        </TextBlock>
                    </Border>
                    <Button Content="🚨 비상정지" Style="{StaticResource EmergencyBtn}" Click="EmergencyStop_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</mah:MetroWindow>
