<mah:MetroWindow x:Class="VisiPickHMI.LogHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        Title="📂 날짜별 로그 이력"
        TitleCharacterCasing="Normal"
        WindowTitleBrush="#0B1120"
        GlowBrush="#3B82F6"
        TitleBarHeight="32"
        TitleForeground="#94A3B8"
        Width="900" Height="600"
        MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#0B1120">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 좌: 날짜 목록 -->
        <Border Grid.Column="0" Background="#151F35" BorderBrush="#1E2D4A"
                BorderThickness="1" CornerRadius="8" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="날짜 선택" FontSize="12" FontWeight="SemiBold"
                           Foreground="#94A3B8" Margin="0,0,0,8"/>

                <ListBox Grid.Row="1" x:Name="DateList"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#E2E8F0" FontSize="13" FontFamily="Consolas"
                         SelectionChanged="DateList_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1A2744"/>
                                    <Setter Property="Foreground" Value="#22D3EE"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#111B2E"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <TextBlock Grid.Row="2" x:Name="TxtDateCount" FontSize="10"
                           Foreground="#64748B" Margin="0,6,0,0"/>
            </Grid>
        </Border>

        <!-- 우: 로그 내용 -->
        <Border Grid.Column="2" Background="#151F35" BorderBrush="#1E2D4A"
                BorderThickness="1" CornerRadius="8" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock x:Name="TxtSelectedDate" Text="날짜를 선택하세요"
                               FontSize="13" FontWeight="SemiBold" Foreground="#94A3B8"/>
                    <TextBlock x:Name="TxtLogCount" FontSize="11" Foreground="#64748B"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>

                <DataGrid Grid.Row="1" x:Name="HistoryGrid"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="None"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          CanUserResizeRows="False" SelectionMode="Single"
                          Background="Transparent" BorderThickness="0"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#0D1525"
                          Foreground="#E2E8F0" FontSize="11" RowHeight="26"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          EnableRowVirtualization="True">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#111B2E"/>
                            <Setter Property="Foreground" Value="#94A3B8"/>
                            <Setter Property="FontSize" Value="10"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="BorderBrush" Value="#1E2D4A"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1A2744"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="8,2"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="시간" Binding="{Binding Timestamp}" Width="155" FontFamily="Consolas"/>
                        <DataGridTextColumn Header="장비" Binding="{Binding Source}" Width="80"/>
                        <DataGridTextColumn Header="유형" Binding="{Binding EventType}" Width="70"/>
                        <DataGridTextColumn Header="메시지" Binding="{Binding Message}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="📄 CSV 내보내기" Height="30" Padding="12,4"
                            FontSize="11" Foreground="#E2E8F0" Background="#1E2D4A"
                            BorderThickness="0" Cursor="Hand" Click="ExportCsv_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="12,4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</mah:MetroWindow>
